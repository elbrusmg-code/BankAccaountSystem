using BusinessLogic.Dtos;
using BusinessLogic.Services.Contract;
using DataAccess.Models.Enums;

namespace BankAccountSystem.UI
{
    public class TransactionMenu
    {
        private readonly ITransactionService _transactionService;
        private readonly IAccountService _accountService;
        private readonly ICustomerService _customerService;

        public TransactionMenu(ITransactionService transactionService, IAccountService accountService, ICustomerService customerService)
        {
            _transactionService = transactionService;
            _accountService = accountService;
            _customerService = customerService;
        }

        public void Show()
        {
            while (true)
            {
                MenuHandler.ShowHeader("TRANZAKSİYA İDARƏETMƏSİ");
                MenuHandler.ShowMenuItem(1, "📄", "Hesaba görə tranzaksiyalar");
                MenuHandler.ShowMenuItem(2, "📈", "Son 30 günün depozitləri");
                MenuHandler.ShowMenuItem(3, "💤", "İnaktiv hesablar");
                MenuHandler.ShowExitItem(0);

                var choice = MenuHandler.ReadMenuChoice(0, 3);

                switch (choice)
                {
                    case 1: GetByAccountId(); break;
                    case 2: GetLast30DaysDeposits(); break;
                    case 3: GetInactiveAccounts(); break;
                    case 0: return;
                }
            }
        }

        private CustomerDto? SelectCustomer()
        {
            var customers = _customerService.GetAllActive(1, 100);
            if (!customers.Any())
            {
                MenuHandler.ShowWarning("Heç bir aktiv müştəri tapılmadı.");
                return null;
            }

            Console.WriteLine();
            Console.ForegroundColor = ConsoleColor.DarkCyan;
            Console.WriteLine("  Müştərilər:");
            Console.ResetColor();

            foreach (var c in customers.OrderBy(c => c.Id))
            {
                MenuHandler.ShowMenuItem(c.Id, "👤", $"{c.FullName} (FİN: {c.NationalId})");
            }
            Console.WriteLine();

            while (true)
            {
                var input = MenuHandler.ReadInt("Müştəri ID seçin (0 - geri)");
                if (input == 0) return null;
                
                var selected = customers.FirstOrDefault(c => c.Id == input);
                if (selected != null)
                    return selected;

                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("  ✖  Sistemdə bu ID ilə aktiv müştəri yoxdur. Zəhmət olmasa siyahıdan seçin.");
                Console.ResetColor();
            }
        }

        private AccountDto? SelectAccount(CustomerDto customer, string prompt = "Hesab ID seçin (0 - geri)", bool includeInactive = false)
        {
            var accounts = _accountService.GetByCustomerId(customer.Id)
                            .Where(a => a.Status == AccountStatus.Active || (includeInactive && a.Status == AccountStatus.Inactive))
                            .ToList();

            if (!accounts.Any())
            {
                MenuHandler.ShowWarning(includeInactive ? $"{customer.FullName} adlı müştərinin aktiv və ya inaktiv hesabı yoxdur." : $"{customer.FullName} adlı müştərinin aktiv hesabı yoxdur.");
                return null;
            }

            Console.WriteLine();
            Console.ForegroundColor = ConsoleColor.DarkCyan;
            Console.WriteLine($"  {customer.FullName} adlı müştərinin Hesabları:");
            Console.ResetColor();

            foreach (var a in accounts.OrderBy(a => a.Id))
            {
                var statusText = a.Status == AccountStatus.Active ? "Aktiv" : "İnaktiv";
                MenuHandler.ShowMenuItem(a.Id, "💳", $"{a.AccountNumber} - Növ: {a.AccountType} - Balans: {a.Balance:N2} AZN - Status: {statusText}");
            }
            Console.WriteLine();

            while (true)
            {
                var input = MenuHandler.ReadInt(prompt);
                if (input == 0) return null;

                var account = accounts.FirstOrDefault(a => a.Id == input);
                if (account != null) return account;

                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("  ✖  Sistemdə bu ID ilə uyğun hesab yoxdur. Zəhmət olmasa siyahıdan seçin.");
                Console.ResetColor();
            }
        }

        private void GetByAccountId()
        {
            MenuHandler.ShowHeader("HESABA GÖRƏ TRANZAKSİYALAR");

            try
            {
                var customer = SelectCustomer();
                if (customer == null) return;

                var account = SelectAccount(customer, includeInactive: true);
                if (account == null) return;

                var transactions = _transactionService.GetByAccountId(account.Id);

                if (!transactions.Any())
                {
                    MenuHandler.ShowWarning("Bu hesaba aid tranzaksiya tapılmadı.");
                    return;
                }

                foreach (var t in transactions)
                    PrintTransaction(t);

                MenuHandler.ShowDivider();
                Console.ForegroundColor = ConsoleColor.DarkGray;
                Console.WriteLine($"  Cəmi: {transactions.Count} tranzaksiya");
                Console.ResetColor();
                Console.ReadLine();
            }
            catch (Exception ex)
            {
                MenuHandler.ShowError(ex.Message);
            }
        }

        private void GetLast30DaysDeposits()
        {
            MenuHandler.ShowHeader("SON 30 GÜNÜN DEPOZİTLƏRİ");

            try
            {
                var transactions = _transactionService.GetLast30DaysDeposits();

                if (!transactions.Any())
                {
                    MenuHandler.ShowWarning("Son 30 gündə depozit tapılmadı.");
                    return;
                }

                foreach (var t in transactions)
                    PrintTransaction(t);

                MenuHandler.ShowDivider();
                var total = transactions.Sum(t => t.Amount);
                Console.ForegroundColor = ConsoleColor.DarkGray;
                Console.WriteLine($"  Cəmi: {transactions.Count} əməliyyat");
                Console.ResetColor();
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine($"  Ümumi məbləğ: {total:N2} AZN");
                Console.ResetColor();
                Console.WriteLine();
                Console.ReadLine();
            }
            catch (Exception ex)
            {
                MenuHandler.ShowError(ex.Message);
            }
        }

        private void GetInactiveAccounts()
        {
            MenuHandler.ShowHeader("İNAKTİV HESABLAR");

            try
            {
                var transactions = _transactionService.GetInactiveAccounts();

                if (!transactions.Any())
                {
                    MenuHandler.ShowWarning("İnaktiv hesab tapılmadı.");
                    return;
                }

                foreach (var t in transactions)
                    PrintTransaction(t);

                MenuHandler.ShowDivider();
                Console.ForegroundColor = ConsoleColor.DarkGray;
                Console.WriteLine($"  Cəmi: {transactions.Count} qeyd");
                Console.ResetColor();
                Console.ReadLine();
            }
            catch (Exception ex)
            {
                MenuHandler.ShowError(ex.Message);
            }
        }

        private static void PrintTransaction(TransactionDto t)
        {
            MenuHandler.ShowDivider();
            MenuHandler.ShowInfo("ID:", t.Id.ToString());
            MenuHandler.ShowInfo("Hesab nömrəsi:", t.AccountNumber);
            MenuHandler.ShowInfo("Növ:", t.Type.ToString());
            MenuHandler.ShowInfo("Məbləğ:", $"{t.Amount:N2} AZN");
            MenuHandler.ShowInfo("Sonraki balans:", $"{t.BalanceAfter:N2} AZN");
            MenuHandler.ShowInfo("Tarix:", t.OccurredAt.ToString("dd.MM.yyyy HH:mm"));

            if (!string.IsNullOrEmpty(t.Description))
                MenuHandler.ShowInfo("Açıqlama:", t.Description);

            if (t.RelatedAccountId.HasValue)
                MenuHandler.ShowInfo("Əlaqəli hesab ID:", t.RelatedAccountId.Value.ToString());
        }
    }
}